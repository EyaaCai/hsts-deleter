{
  "manifest_version": 3,
  "name": "HSTS Deleter Auto",
  "version": "1.1.0",
  "description": "自动获取当前域名并辅助删除 HSTS 策略",
  "permissions": ["tabs", "activeTab"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["edge://net-internals/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
